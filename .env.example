# ==============================================
# MapBiomas Alerta API — Server-Side Credentials
# ==============================================
# These are read ONLY by the proxy server (server/proxy.mjs).
# They are NEVER exposed in the browser/frontend bundle.
#
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env

MAPBIOMAS_EMAIL=seu-email@exemplo.com
MAPBIOMAS_PASSWORD=sua-senha-aqui

# Port for the proxy server (default: 3001)
PROXY_PORT=3001

# Comma-separated list of allowed CORS origins for the proxy server
# In production, replace with your actual domain(s)
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# =============================================
# IMPORTANT: Do NOT use VITE_MAPBIOMAS_* vars!
# Variables with the VITE_ prefix are embedded
# in the frontend JS bundle and visible to users.
# =============================================

# =============================================
# Supabase Configuration
# =============================================
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
